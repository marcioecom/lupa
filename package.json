{
  "name": "lupa",
  "version": "0.1.0",
  "private": true,
  "description": "ETL + API for TCE-TO transparency portal (licitacoes, contratos, obras)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "scrape:licitacao": "tsx src/cli/scrape-licitacao.ts",
    "scrape:contrato": "tsx src/cli/scrape-contrato.ts",
    "api": "tsx src/cli/serve.ts",
    "api:dev": "tsx watch src/cli/serve.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.55.3",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "iconv-lite": "^0.6.3",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
